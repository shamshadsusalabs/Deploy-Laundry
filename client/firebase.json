{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/apk",
        "destination": "/apk-download.html",
        "type": 302
      }
    ],
    "rewrites": [
      {
        "source": "/privacy-policy.html",
        "destination": "/privacy-policy.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
